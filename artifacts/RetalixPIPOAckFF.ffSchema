			length = 2
			maxLength = 2
			minLength = 2
			readEmptyAsNull = true
		)
		customerItemNumber String (
			length = 15
			maxLength = 15
			minLength = 15
			readEmptyAsNull = true
		)
		itemNumber String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		itemStatus String (
			length = 2
			maxLength = 2
			minLength = 2
			readEmptyAsNull = true
		)
		purchaseUnit String (
			length = 2
			maxLength = 2
			minLength = 2
			readEmptyAsNull = true
		)
		quantityConfirmed Integer (
			length = 7
			maxLength = 7
			minLength = 7
			readEmptyAsNull = true
		)
		priceConfirmed Decimal (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		quantityOrdered Integer (
			length = 7
			maxLength = 7
			minLength = 7
			readEmptyAsNull = true
		)
		priceOrdered Decimal (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		averageWeight Decimal (
			length = 8
			maxLength = 8
			minLength = 8
			readEmptyAsNull = true
		)
		activeItem String (
			length = 1
			maxLength = 1
			minLength = 1
			readEmptyAsNull = true
		)
		catchweightFlag String (
			length = 1
			maxLength = 1
			minLength = 1
			readEmptyAsNull = true
		)
	}

	def record OpaDtl2 {
		fieldIdentifier {
			value = "OPA_DTL2"
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		itemDescription String (
			length = 40
			maxLength = 40
			minLength = 40
			readEmptyAsNull = true
		)
	}

	def record OpaDtl3 {
		fieldIdentifier {
			value = "OPA_DTL3"
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		englishDescription String (
			length = 40
			maxLength = 40
			minLength = 40
			readEmptyAsNull = true
		)
		frenchDescription String (
			length = 40
			maxLength = 40
			minLength = 40
			readEmptyAsNull = true
		)
	}

	def record OpaTtl1 {
		fieldIdentifier {
			value = "OPA_TTL1  "
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		lineCount Integer (
			length = 6
			maxLength = 6
			minLength = 6
			readEmptyAsNull = true
		)
		quantityTotal Integer (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
		recordCount Integer (
			length = 6
			maxLength = 6
			minLength = 6
			readEmptyAsNull = true
		)
	}

	def record TPM2_HDR {
		fieldIdentifier {
			value = "TPM2_HDR"
			field = recordType
		}

		recordType String (
			length = 10
		)
		SAP_SalesOrderNbr String (
			length = 20
		)
		Manifest String (
			length = 20
		)
		SAP_Plant String (
			length = 4
		)
		SAP_Organization String (
			length = 4
		)
		SAP_Division String (
			length = 4
		)
		SAP_DistChannel String (
			length = 4
		)
	}

	def record OpaRef1 {
		fieldIdentifier {
			value = "OPA_REFH1"
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		RefQual String (
			length = 3
			maxLength = 3
			minLength = 3
		)
		RefId String (
			length = 30
			maxLength = 30
			minLength = 30
		)
	}

	def recordSequence OTpidGroup {
		groupOnRecord = true

		_oTpid OTpid []
		_opaHdra OpaHdra []
		_opaHdr1 OpaHdr1 []
		_OpaRef1 OpaRef1 []
		_opaSt1 OpaSt1 []
		_opaVn1 OpaVn1 []
		_TPM2_HDR TPM2_HDR []
		_opaDtl1Group OpaDtl1Group []
		_opaTtl1 OpaTtl1 []
	}

	def recordSequence OpaDtl1Group {

		_opaDtl1 OpaDtl1 []
		_opaDtl2 OpaDtl2 []
		_opaDtl3 OpaDtl3 []
	}
}