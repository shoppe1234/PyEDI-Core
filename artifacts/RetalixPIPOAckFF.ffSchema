			length = 50
			maxLength = 50
			minLength = 50
			readEmptyAsNull = true
		)
		distributorID Integer (
			length = 15
			maxLength = 15
			minLength = 15
			readEmptyAsNull = true
		)
	}

	def record OpaDtl1 {
		fieldIdentifier {
			value = "OPA_DTL1  "
