package com.gfs.customer.ca.core.system.schemas ;

/*RetalixPIPOAck 1.0*/
def flatFileSchema RetalixPIPOAckFF {
	delimiter = "|"

	_oTpidGroup OTpidGroup []

	def record OTpid {
		fieldIdentifier {
			value = "O_TPID"
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		tpID String (
			length = 20
			maxLength = 20
			minLength = 20
		)
	}

	def record OpaHdra {
		fieldIdentifier {
			value = "OPA_HDRA   "
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		companyNumber Integer (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
		divisionNumber Integer (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
		locationNumber Integer (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
		warehouseNumber Integer (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
		customerNumber Integer (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
	}

	def record OpaHdr1 {
		fieldIdentifier {
			value = "OPA_HDR1  "
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		ackType String (
			length = 2
			maxLength = 2
			minLength = 2
			readEmptyAsNull = true
		)
		pONumber String (
			length = 20
			maxLength = 20
			minLength = 20
			readEmptyAsNull = true
		)
		pODate String (
			length = 8
			maxLength = 8
			minLength = 8
			readEmptyAsNull = true
		)
		requestedShipDate String (
			length = 8
			maxLength = 8
			minLength = 8
			readEmptyAsNull = true
		)
		projectedShipDate String (
			length = 8
			maxLength = 8
			minLength = 8
			readEmptyAsNull = true
		)
		orderNumber Integer (
			length = 7
			maxLength = 7
			minLength = 7
			readEmptyAsNull = true
		)
		contractOrderNumber String (
			length = 20
			maxLength = 20
			minLength = 20
			readEmptyAsNull = true
		)
	}

	def record OpaSt1 {
		fieldIdentifier {
			value = "OPA_ST1   "
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		shipToNameNU String (
			length = 25
			maxLength = 25
			minLength = 25
			readEmptyAsNull = true
		)
		shipToIDQualNU String (
			length = 2
			maxLength = 2
			minLength = 2
			readEmptyAsNull = true
		)
		shipToIDNU String (
			length = 15
			maxLength = 15
			minLength = 15
			readEmptyAsNull = true
		)
		shipToStoreNumber String (
			length = 20
			maxLength = 20
			minLength = 20
			readEmptyAsNull = true
		)
		erpCustomerNumber String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
		)
		languageCode String (
			length = 3
			maxLength = 3
			minLength = 3
			readEmptyAsNull = true
		)
	}

	def record OpaVn1 {
		fieldIdentifier {
			value = "OPA_VN1   "
			field = recordType
		}

		recordType String (
			length = 10
			maxLength = 10
			minLength = 10
			readEmptyAsNull = true
